{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grinder-plan.schema.json",
  "$comment": "Defines the grinder execution plan (DAG of batches grouped by pass). Semantic validations not expressible in JSON Schema: (1) depends_on references must resolve to existing batch IDs (dangling-reference check), (2) the batch dependency graph must be acyclic (cycle detection), (3) batch IDs must be unique across the entire plan, (4) coverage batches use cov- prefixed IDs, (5) needs_review is specific to coverage pass batches. Checks 1-3 enforced by the Python validator (schema-validators task), not this schema.",
  "type": "object",
  "required": ["created_at", "git_sha_at_start", "estimated_batches", "estimated_hours", "passes"],
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "git_sha_at_start": {
      "type": "string",
      "minLength": 1
    },
    "estimated_batches": {
      "type": "integer",
      "minimum": 0
    },
    "estimated_hours": {
      "type": "number",
      "minimum": 0
    },
    "passes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pass" }
    },
    "staleness_commit_threshold": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "batch_size": {
      "type": "integer",
      "minimum": 1,
      "default": 5
    },
    "project": {
      "type": "string"
    }
  },
  "$defs": {
    "pass": {
      "type": "object",
      "required": ["id", "kind", "batches"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["mechanical", "coverage", "static_analysis", "cve"]
        },
        "batches": {
          "type": "array",
          "items": { "$ref": "#/$defs/batch" }
        }
      }
    },
    "batch": {
      "type": "object",
      "required": ["id", "files", "estimated_turns", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "estimated_turns": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "failed", "deferred"]
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "churn_score": {
          "type": "number",
          "minimum": 0
        },
        "needs_review": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
