{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch"
    ],
    "deny": [
      "Edit(//.ssh/**)",
      "Write(//.ssh/**)",
      "Read(//.ssh/**)",
      "Edit(//.aws/**)",
      "Write(//.aws/**)",
      "Read(//.aws/**)",
      "Edit(//.gnupg/**)",
      "Write(//.gnupg/**)",
      "Read(//.gnupg/**)",
      "Edit(//.azure/**)",
      "Write(//.azure/**)",
      "Read(//.azure/**)",
      "Edit(//.kube/**)",
      "Write(//.kube/**)",
      "Read(//.kube/**)",
      "Edit(//.npmrc)",
      "Write(//.npmrc)",
      "Read(//.npmrc)",
      "Edit(//.pypirc)",
      "Write(//.pypirc)",
      "Read(//.pypirc)",
      "Edit(//.git-credentials)",
      "Write(//.git-credentials)",
      "Read(//.git-credentials)",
      "Edit(//.netrc)",
      "Write(//.netrc)",
      "Read(//.netrc)",
      "Edit(//.bashrc)",
      "Write(//.bashrc)",
      "Edit(//.zshrc)",
      "Write(//.zshrc)",
      "Edit(//.claude/settings.json)",
      "Write(//.claude/settings.json)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/notify-macos.sh", "async": true }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash -c '[ -x ./scripts/verify_before_done.sh ] && ./scripts/verify_before_done.sh || true'" }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "bash -c '[ -x ./scripts/verify_before_done.sh ] && ./scripts/verify_before_done.sh || true'" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/tdd-gate.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/lint-on-edit.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/log-bash.sh", "async": true }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "mkdir -p \"${TMPDIR:-/tmp/claude}\" 2>/dev/null || true" }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/log-permissions.sh", "async": true }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "objects.githubusercontent.com",
        "uploads.github.com",
        "registry.npmjs.org",
        "*.pypi.org",
        "pypi.org",
        "api.anthropic.com",
        "api.openai.com",
        "*.googleapis.com"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [],
    "filesystem": {
      "allowWrite": [
        "~/Projects",
        "//tmp",
        "~/.cache",
        "~/.docker"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.azure",
        "~/.kube",
        "~/.npmrc",
        "~/.pypirc",
        "~/.git-credentials",
        "~/.netrc",
        "~/.bash_history",
        "~/.zsh_history",
        "~/Library/Keychains"
      ]
    }
  },
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "effortLevel": "max"
}
