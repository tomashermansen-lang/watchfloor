{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-agent-dashboard/execution-plan.schema.json",
  "title": "Execution Plan",
  "description": "Structured execution plan for project monitoring dashboards",
  "type": "object",
  "required": ["schema_version", "name", "phases"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of the schema"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Project or feature name"
    },
    "description": {
      "type": "string",
      "description": "One-paragraph summary"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 creation date (YYYY-MM-DD)"
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" },
      "description": "Source document references"
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 last-updated date (YYYY-MM-DD)"
    },
    "changelog": {
      "type": "array",
      "items": { "$ref": "#/$defs/changelog_entry" },
      "description": "Ordered list of plan changes (newest last)"
    },
    "extensions": {
      "type": "object",
      "description": "Custom metadata (opaque to dashboard)"
    },
    "phases": {
      "type": "array",
      "items": { "$ref": "#/$defs/phase" },
      "description": "Ordered array of phases"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "phase": {
      "type": "object",
      "required": ["id", "name", "tasks"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/task" }
        },
        "gate": { "$ref": "#/$defs/gate" },
        "extensions": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "required": ["id", "name", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "wip", "done", "failed", "skipped", "blocked"]
        },
        "depends": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prompt": {
          "type": "string"
        },
        "acceptance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parallel_group": {
          "type": "string"
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "delivered_beyond_plan": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Items delivered that were not in the original plan"
        },
        "scope_change": {
          "type": "string",
          "description": "Description of how scope changed from original plan"
        },
        "remaining_gaps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known gaps remaining after task completion"
        },
        "autopilot": {
          "type": "boolean",
          "default": false,
          "description": "Whether this task can run the full pipeline without human checkpoints. Set by planning team based on: no UI, no manual testing needed, no ambiguous requirements, no novel architecture decisions, no security-sensitive changes."
        },
        "pipeline": {
          "type": "string",
          "enum": ["full", "light"],
          "default": "full",
          "description": "Pipeline weight for autopilot. full: BA → Plan → Team Review → Implement → Static Analysis → Team QA (complex tasks). light: BA → Plan → Review → Implement → Static Analysis → QA (simple tasks, known patterns). Only meaningful when autopilot: true."
        },
        "extensions": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "changelog_entry": {
      "type": "object",
      "required": ["date", "type", "description"],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date of the change (YYYY-MM-DD)"
        },
        "type": {
          "type": "string",
          "enum": ["added", "removed", "restructured", "modified"],
          "description": "Type of change"
        },
        "description": {
          "type": "string",
          "description": "What changed and why"
        },
        "affected_tasks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Task IDs affected by this change"
        },
        "affected_phases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Phase IDs affected by this change"
        }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": ["name", "checklist", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "checklist": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "passed": {
          "type": "boolean"
        },
        "command": {
          "type": "string"
        },
        "notes": {
          "type": "string",
          "description": "Freeform notes about gate status or caveats"
        }
      },
      "additionalProperties": false
    }
  }
}
