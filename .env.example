# Claude Code Pipeline — Environment Variables
#
# These are optional overrides. The install.sh script configures
# project-dirs.conf which handles most of this automatically.

# Root directory containing all your projects (default: ~/Projects)
# PROJECTS_ROOT="$HOME/Projects"

# Dashboard data file for autopilot session logging (default: auto-detected)
# CLAUDE_DASHBOARD_DATA="$PROJECTS_ROOT/claude-agent-dashboard/data/sessions.jsonl"

# SonarQube token for static analysis (optional)
# SONAR_TOKEN="your-token-here"
