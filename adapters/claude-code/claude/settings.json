{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch"
    ],
    "deny": [
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Read(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Read(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.azure/**)",
      "Write(~/.azure/**)",
      "Read(~/.azure/**)",
      "Edit(~/.kube/**)",
      "Write(~/.kube/**)",
      "Read(~/.kube/**)",
      "Edit(~/.npmrc)",
      "Write(~/.npmrc)",
      "Read(~/.npmrc)",
      "Edit(~/.pypirc)",
      "Write(~/.pypirc)",
      "Read(~/.pypirc)",
      "Edit(~/.git-credentials)",
      "Write(~/.git-credentials)",
      "Read(~/.git-credentials)",
      "Edit(~/.netrc)",
      "Write(~/.netrc)",
      "Read(~/.netrc)",
      "Edit(~/.bashrc)",
      "Write(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Write(~/.zshrc)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/hooks/**)",
      "Write(~/.claude/hooks/**)",
      "Edit(~/.claude/agents/**)",
      "Write(~/.claude/agents/**)",
      "Edit(~/.claude/commands/**)",
      "Write(~/.claude/commands/**)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Edit(~/.claude/rules/**)",
      "Write(~/.claude/rules/**)",
      "Edit(~/.claude/CLAUDE.md)",
      "Write(~/.claude/CLAUDE.md)",
      "Read(~/Library/Cookies/**)",
      "Read(~/Library/Application Support/Google/Chrome/**)",
      "Read(~/Library/Application Support/Firefox/**)",
      "Read(~/Library/Application Support/BraveSoftware/**)",
      "Read(~/Library/Application Support/1Password/**)",
      "Read(~/Library/Group Containers/2BUA8C4S2C.com.1password/**)",
      "Read(~/Library/Application Support/Bitwarden/**)",
      "Read(~/Library/Mail/**)",
      "Read(~/Library/Messages/**)",
      "Read(~/Library/Group Containers/group.com.apple.messages/**)",
      "Read(~/Library/Application Support/Slack/**)",
      "Read(~/Library/Application Support/Signal/**)",
      "Read(~/Library/Mobile Documents/**)",
      "Read(~/Library/CloudStorage/**)",
      "Read(~/Documents/**)",
      "Read(~/Desktop/**)",
      "Read(~/Pictures/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "SONAR_TOKEN": "sqa_0c6a69b88b1756e4f49403db6146be33e80e74b0",
    "PLAN_OWNERSHIP_GUARD_MODE": "warn"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-macos.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash -c '[ -x ./scripts/verify_before_done.sh ] && ./scripts/verify_before_done.sh || true'"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/phase-artifact-stop-guard.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash -c '[ -x ./scripts/verify_before_done.sh ] && ./scripts/verify_before_done.sh || true'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/edit-write-allowlist.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/plan-ownership-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/plan-ownership-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lint-on-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-bash.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/classify-bash-result.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"${TMPDIR:-/tmp/claude}\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projekter/dotfiles/dashboard/hooks/report-status.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-permissions.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
