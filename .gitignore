# OS
.DS_Store

# Don't track backups created during sync
*.bak

# Python
__pycache__/
*.pyc
.venv/
.coverage
# Subprocess coverage data — coverage.py writes one .coverage.<host>.<pid>.<rand>
# per child Python process when [tool.coverage.run] parallel=true. They're
# merged by `coverage combine` into .coverage and should never be tracked.
.coverage.*
coverage.xml
*.egg-info/
build/
dist/

# JS/TS coverage reports (vitest/jest output)
**/coverage/

# SonarQube scanner ephemeral output (regenerated each run)
.scannerwork/
**/.scannerwork/
# Project-local SonarQube user-home cache used as the sandbox-friendly
# SONAR_USER_HOME workaround (see env-gap-sonar-user-home in any plan).
.sonar/
**/.sonar/

# uv
uv.lock

# Autopilot summaries (runtime artifacts, not source)
docs/DONE_Feature_*/autopilot-summary.json
# In-progress autopilot streams (runtime artifacts, not source)
docs/INPROGRESS_Feature_*/autopilot-stream.ndjson
# Tests-green SHA marker — written by /implement (end of Step 5), /qa
# (after fix loop), and /static-analysis (after fix loop) when tests +
# lint + type-check exit green. commit-preflight.sh reads it to skip a
# redundant full test rerun. Purely local.
docs/INPROGRESS_Feature_*/.tests-green-sha
docs/DONE_Feature_*/.tests-green-sha

# Local Claude config — operator-private session data is ignored worktree-wide.
# Deployable adapter assets at adapters/claude-code/.claude/ are explicitly
# allow-listed below so future Claude Code versions cannot accidentally leak
# new operator-private subpaths into the index.
.claude/**
!adapters/claude-code/.claude/settings.json
!adapters/claude-code/.claude/hooks/
!adapters/claude-code/.claude/commands/
!adapters/claude-code/.claude/agents/
!adapters/claude-code/.claude/skills/
!adapters/claude-code/.claude/rules/
!adapters/claude-code/.claude/CLAUDE.md

# Plan lockfiles — runtime artifacts written alongside execution-plan.yaml.
# The lock filename derives from plan_path.with_suffix(plan_path.suffix + ".lock");
# for execution-plan.yaml that produces execution-plan.yaml.lock.
docs/INPROGRESS_Plan_*/*.lock

# Chain runtime state (per-plan, not source)
docs/INPROGRESS_Plan_*/chain-state.json
docs/INPROGRESS_Plan_*/chain-events.ndjson
docs/INPROGRESS_Plan_*/chain-stdout.log
docs/INPROGRESS_Plan_*/chain.PAUSE
docs/INPROGRESS_Plan_*/.chain-exit-*
docs/INPROGRESS_Plan_*/merge.lock
docs/DONE_Plan_*/chain-state.json
# chain-events.ndjson is INTENTIONALLY tracked under DONE_Plan_* so the
# council_brief_builder friction-mining pass (and any future retro)
# can read the chain-level event history of completed plans. See the
# 2026-05-21 fix in council_brief_builder.py that widened the glob
# from INPROGRESS_Plan_* to include DONE_Plan_* too.
docs/DONE_Plan_*/chain-stdout.log
docs/DONE_Plan_*/chain.PAUSE
docs/DONE_Plan_*/.chain-exit-*
docs/DONE_Plan_*/merge.lock

# Grinder runtime state (per-run, not source)
docs/grinder/grinder-state.json
docs/grinder/grinder-stream.ndjson
# Per-cycle plan + event log — regenerated by every `grinder.sh discover`.
# Used to be committed as a discover audit trail but mutating them every
# run kept tripping sync.sh's clean-tree guard. History recoverable via
# *.<short-sha>.bak archives written by _archive_prior_cycle_logs in
# claude/tools/lib/grinder-discover.sh; the git commits per batch capture
# the actual code-fix audit trail.
docs/grinder/events.ndjson
docs/grinder/grinder-plan.yaml
# Raw scanner outputs — regenerated every discover, gigantic JSON noise
# in diffs, no useful git history. baseline.json (emitted by Phase 7)
# stays tracked as the project's quality-debt source of truth.
docs/grinder/scanner-output/
# Transient runtime markers — lock held during execution, PAUSE set by
# the operator to halt at next batch boundary. Neither should be tracked
# or block sync.sh's working-tree-clean check.
docs/grinder/.grinder.lock
docs/grinder/PAUSE

# Secrets — keys must never be committed.
# secrets/README.md and secrets/*.env.example ARE tracked (templates).
# secrets/*.env is the operator-local copy (gitignored).
secrets/*.env
!secrets/*.env.example
# Adapter-local secrets workaround until T3 path-references-update fixes
# openai-key.sh to read root-level secrets/. Same content as secrets/*.env,
# just at the path the post-restructure script looks for.
adapters/claude-code/secrets/*.env
!adapters/claude-code/secrets/*.env.example
